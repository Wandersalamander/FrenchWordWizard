<resources>
    <!-- Light mode: Monokai pink/cyan accents on a warm cream canvas, with the
         action bar pinned to Monokai BG so the top of the screen reads as
         editor chrome regardless of the system theme. -->
    <style name="Theme.MyApplication" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Iconic pink for primary actions: NEXT, dialog confirm, switches. -->
        <item name="colorPrimary">@color/monokai_pink</item>
        <item name="colorPrimaryVariant">@color/monokai_pink_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Cyan secondary for FAB / accent components. -->
        <item name="colorSecondary">@color/monokai_cyan</item>
        <item name="colorSecondaryVariant">@color/monokai_cyan_dark</item>
        <item name="colorOnSecondary">@color/monokai_bg</item>
        <item name="colorAccent">@color/monokai_cyan</item>

        <!-- Cream paper surface, pure black for body copy. Monokai BG (#272822)
             reads as olive-tinted gray on cream rather than crisp black, so we
             push primary text to true black for legibility; only the muted
             secondary/tertiary tiers carry the Monokai olive warmth. -->
        <item name="android:colorBackground">@color/cream_surface</item>
        <item name="colorSurface">@color/cream_surface</item>
        <item name="colorOnSurface">@color/black</item>

        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/monokai_comment</item>
        <item name="android:textColorTertiary">@color/monokai_comment_light</item>

        <!-- Action bar + status bar share Monokai BG so the top of every
             screen reads as a code-editor frame. -->
        <item name="actionBarStyle">@style/Widget.MyApplication.ActionBar</item>
        <item name="android:statusBarColor">@color/monokai_bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Widget.MyApplication.ActionBar" parent="Widget.AppCompat.ActionBar.Solid">
        <item name="background">@color/monokai_bg</item>
        <item name="elevation">2dp</item>
    </style>
</resources>
