<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Brand palette. The previous values referenced @android:color/* aliases
         that resolve differently across API levels; switching to literal hex
         keeps the brand stable. -->
    <color name="brand_primary">#6750A4</color>
    <color name="brand_primary_dark">#4F378B</color>
    <color name="brand_primary_light">#D0BCFF</color>
    <color name="brand_secondary">#03DAC5</color>
    <color name="brand_secondary_dark">#018786</color>

    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <!-- Semantic tokens. Each has a night counterpart in values-night/colors.xml
         so views referencing these names follow the system theme. -->
    <color name="text_secondary">#5B5B66</color>
    <color name="text_tertiary">#8A8A95</color>
    <color name="danger">#C62828</color>
    <color name="on_danger">#FFFFFFFF</color>
    <!-- Tint overlaid on the colored skill bar to mark the "finished" portion.
         In light mode white reads as a bright highlight on the saturated bar;
         see values-night for the dark-mode tweak. -->
    <color name="progress_finished_overlay">#FFFFFFFF</color>

    <!-- Monokai palette — used as per-skill accents on progress bars. These are
         intentional vivid accents that read well on both light and dark
         backgrounds, so they do not have night counterparts. -->
    <color name="monokai_green">#A6E22E</color>
    <color name="monokai_cyan">#66D9EF</color>
    <color name="monokai_orange">#FD971F</color>
    <color name="monokai_pink">#F92672</color>
    <color name="monokai_purple">#AE81FF</color>
    <color name="monokai_yellow">#E6DB74</color>
</resources>
