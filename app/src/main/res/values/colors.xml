<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Monokai canonical palette. Hex values are the original Monokai theme
         constants (background, foreground, comment, plus the six syntax
         accents). The *_dark / *_light additions and bg_lift are derived for
         status-bar variants and elevated surfaces. -->
    <color name="monokai_bg">#272822</color>
    <color name="monokai_bg_lift">#3E3D32</color>
    <color name="monokai_fg">#F8F8F2</color>
    <color name="monokai_comment">#75715E</color>
    <color name="monokai_comment_light">#A59F85</color>
    <color name="monokai_pink">#F92672</color>
    <color name="monokai_pink_dark">#C71B5C</color>
    <color name="monokai_orange">#FD971F</color>
    <color name="monokai_yellow">#E6DB74</color>
    <color name="monokai_green">#A6E22E</color>
    <color name="monokai_cyan">#66D9EF</color>
    <color name="monokai_cyan_dark">#3FB8D1</color>
    <color name="monokai_purple">#AE81FF</color>

    <!-- Warm cream paper for light-mode content surfaces. Sits between pure
         white and the Monokai foreground so the editor feel carries over to
         daylight without looking dingy. -->
    <color name="cream_surface">#FAF8F0</color>

    <!-- Card surface — slightly lighter/whiter than the cream canvas so cards
         read as raised editor panes in light mode. values-night flips this to
         monokai_bg_lift for the same dark-mode lift effect. -->
    <color name="card_surface">#FFFEF8</color>
    <!-- Hairline card edge: olive Monokai comment at low alpha so the stroke
         defines the panel without competing with the colored top accent. -->
    <color name="card_edge">#33756F5E</color>

    <!-- Unfilled portion of the progress bars. Needs to read against the card
         surface, so it's noticeably darker than card_surface in light mode and
         (via values-night) noticeably darker than bg_lift in dark mode —
         giving the bar a recessed-groove feel either way. -->
    <color name="progress_track">#E5DDC4</color>

    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <!-- Mode-flipping text color for the main vocab views (textGuess, textReal,
         textGuessLong). Applied explicitly on those TextViews so Material's
         default TextAppearance can't sneak a high-emphasis alpha overlay on
         top — that's what was making the vocab look dim/grayish even on a
         "near-black" textColorPrimary. -->
    <color name="vocab_text">#000000</color>

    <!-- Semantic tokens. values-night overrides only those whose meaning
         flips in dark mode. -->
    <color name="danger">#C62828</color>
    <color name="on_danger">#FFFFFFFF</color>

    <!-- ============================================================
         Accessibility-tuned semantic tokens for card surfaces.

         The raw Monokai palette is calibrated for the dark canvas it
         was designed on; on the cream light surface several of those
         hues sit at ~1.5-2.5:1 contrast and fail WCAG 2.1 AA. These
         tokens give every "colored label / segment / count" a mode-
         aware hex that clears 3:1 (graphics) or 4.5:1 (text). The
         original monokai_* swatches are still used for hue-coded
         chrome (card top stripes, vocab card accent) where contrast
         isn't load-bearing.
         ============================================================ -->

    <!-- Small muted labels on card surfaces (CardEyebrow style, " / total"
         connector text, etc.). Light: Monokai 'comment' (~5:1 vs cream).
         Dark override lifts it so it still clears 4.5:1 on bg_lift. -->
    <color name="card_eyebrow">#75715E</color>
    <color name="card_text_muted">#75715E</color>

    <!-- Lifetime mastery bar fill — darker green for cream, original
         monokai_green in dark. Same hue family, just deepened. -->
    <color name="seg_mastered">#3F7E0E</color>

    <!-- Active-pool segment fills, one per skill. Light values are deeper
         siblings of the orange/cyan/purple Monokai accents. -->
    <color name="seg_read">#B45309</color>
    <color name="seg_listen">#0E7490</color>
    <color name="seg_invert">#6D28D9</color>

    <!-- Mode-aware variants of the lifetime/today label highlights. -->
    <color name="lifetime_count_color">#3F7E0E</color>
    <color name="today_count_color">#B45309</color>

    <!-- Streak counter digit colour. Darker than monokai_orange so the
         number reads against cream (the 🔥 emoji is system-coloured and
         carries the warm tone visually regardless). -->
    <color name="streak_count_color">#9A3412</color>
    <color name="streak_shield_color">#75715E</color>
</resources>
