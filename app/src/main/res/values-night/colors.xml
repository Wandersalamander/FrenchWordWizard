<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Slightly desaturated red so the danger button doesn't glow against
         a dark Monokai surface. on_danger flips to Monokai BG so the label
         stays high-contrast on the muted red. -->
    <color name="danger">#E57373</color>
    <color name="on_danger">@color/monokai_bg</color>

    <color name="vocab_text">#FFFFFF</color>

    <!-- Cards lift off the Monokai canvas using bg_lift, matching the dark
         theme's elevated-surface convention. -->
    <color name="card_surface">#3E3D32</color>
    <!-- Brighter olive at low alpha so the panel edge stays readable against
         the dark canvas without flattening into the bg_lift fill. -->
    <color name="card_edge">#4DA59F85</color>

    <!-- Darker than the bg_lift card surface so the unfilled bar reads as a
         recessed groove cut into the panel. -->
    <color name="progress_track">#272822</color>

    <!-- Dark-mode overrides for the accessibility-tuned semantic tokens.
         The raw Monokai accents already pass ≥3:1 against monokai_bg /
         bg_lift, so segments/counts revert to their original hues. The
         muted text tokens lift slightly from monokai_comment_light so
         they still clear 4.5:1 on bg_lift. -->
    <color name="card_eyebrow">#BCB59A</color>
    <color name="card_text_muted">#BCB59A</color>
    <color name="seg_mastered">#A6E22E</color>
    <color name="seg_read">#FD971F</color>
    <color name="seg_listen">#66D9EF</color>
    <color name="seg_invert">#AE81FF</color>
    <color name="lifetime_count_color">#A6E22E</color>
    <color name="today_count_color">#E6DB74</color>
    <color name="streak_count_color">#FD971F</color>
    <color name="streak_shield_color">#BCB59A</color>
</resources>
