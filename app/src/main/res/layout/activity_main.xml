<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textGuess"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:text="Un mot etrange et aussi trop long"
        android:textSize="34sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.115" />

    <TextView
        android:id="@+id/textReal"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:text="A foreign word"
        android:textSize="24sp"
        app:layout_constraintStart_toStartOf="@+id/textGuess"
        app:layout_constraintTop_toBottomOf="@+id/textGuess" />

    <TextView
        android:id="@+id/textGuessLong"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Ma mère a ressenti une très grande peine lorsqu’elle a appris que mon père servirait une peine de six ans pour un crime qu’il n’a pas commis. "
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/textGuess"
        app:layout_constraintTop_toBottomOf="@+id/textReal" />

    <ImageView
        android:id="@+id/thinking_sparkle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="6dp"
        android:layout_marginStart="-4dp"
        android:contentDescription="@null"
        android:src="@drawable/thinking_sparkle"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="@+id/textGuessLong"
        app:layout_constraintTop_toTopOf="@+id/textGuessLong" />

    <TextView
        android:id="@+id/textScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0.00"
        android:textSize="24sp"
        app:layout_constraintBottom_toTopOf="@+id/textGuess"
        app:layout_constraintStart_toStartOf="@+id/textGuess" />

    <TextView
        android:id="@+id/textStreak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="16dp"
        android:text=""
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/monokai_orange"
        android:contentDescription="Current practice streak in days"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/button_hard"
        style="?android:attr/buttonBarButtonStyle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="⚑"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/textGuessLong"
        app:layout_constraintStart_toEndOf="@+id/textReal"
        app:layout_constraintTop_toBottomOf="@+id/textScore"
        app:layout_constraintVertical_bias="0.0" />

    <Button
        android:id="@+id/button_learned"
        style="?android:attr/buttonBarButtonStyle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="✓"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@+id/textScore"
        app:layout_constraintStart_toEndOf="@+id/textGuess" />


    <Button
        android:id="@+id/button_next"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:text="Next"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/button_fail"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.843" />

    <Button
        android:id="@+id/button_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:text="Tip"
        app:layout_constraintBottom_toBottomOf="@+id/button_new"
        app:layout_constraintEnd_toStartOf="@+id/button_new"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/button_fail"
        app:layout_constraintTop_toTopOf="@+id/button_new"
        app:layout_constraintVertical_bias="0.0" />

    <Button
        android:id="@+id/button_new"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="A NEW WORD"
        app:layout_constraintEnd_toEndOf="@+id/button_next"
        app:layout_constraintTop_toBottomOf="@+id/button_next" />

    <Button
        android:id="@+id/button_fail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:text="I don't know"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/button_next" />

    <androidx.constraintlayout.widget.Group
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:layout_editor_absoluteX="102dp"
        tools:layout_editor_absoluteY="123dp" />

    <LinearLayout
        android:id="@+id/progressContainer"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toTopOf="@+id/button_fail"
        app:layout_constraintStart_toStartOf="@+id/button_fail">

        <TextView
            android:id="@+id/textProgressTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="14sp" />

        <!-- Per-skill bar rows are inflated into here at runtime, one per Skill.ladder
             entry. FrameLayout makes them share the same Y position so they appear
             stacked rather than tiled. -->
        <FrameLayout
            android:id="@+id/progressBarsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>