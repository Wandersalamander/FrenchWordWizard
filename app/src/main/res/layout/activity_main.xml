<?xml version="1.0" encoding="utf-8"?>
<!-- Main quiz screen, grouped into four editor-pane "cards":

       1. cardStreak    (orange) — daily streak fire + stockpiled shields.
       2. cardVocab     (pink)   — score header, foreign word, translation,
                                   example sentence, plus the per-word
                                   flag (⚑) and learned (✓) buttons.
       3. cardLifetime  (green)  — lifetime mastery bar + "{mastered} / {total}"
                                   label with the +N-today highlight.
       4. cardActive    (cyan)   — current active-pool composition bar,
                                   segmented per skill.

     Vertical LinearLayout splits the screen cleanly: streak + vocab anchor
     at the top, a weight=1 Space absorbs any vertical slack, the two
     progress cards and the 2×2 button grid form a fixed bottom block.
     Each card's top-stripe color matches the data inside (see
     drawable/bg_card_*.xml). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="14dp"
    android:paddingBottom="20dp"
    tools:context=".MainActivity">

    <!-- ============================ STREAK CARD ============================
         Single row: title on the left, shield + fire grouped on the right.
         Vertically tighter than the other cards' default 12/14 dp padding
         because the shield/fire icons already carry plenty of visual weight;
         giving them a 36dp tap target (instead of the 48dp default) keeps
         the card compact while staying tappable — the TouchTargetSizeCheck
         lint is intentionally suppressed for this reason. baselineAligned
         is disabled so the small title's baseline isn't pulled down to
         meet the much larger icon text. -->
    <LinearLayout
        android:id="@+id/cardStreak"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_orange"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingTop="8dp"
        android:paddingBottom="10dp">

        <TextView
            style="@style/CardEyebrow"
            android:layout_width="0dp"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:text="STREAK" />

        <TextView
            android:id="@+id/textStreakShield"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="40dp"
            android:minHeight="36dp"
            android:padding="6dp"
            android:text=""
            android:textColor="@color/streak_shield_color"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:ignore="TouchTargetSizeCheck"
            tools:text="🛡️ 3" />

        <TextView
            android:id="@+id/textStreak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingHorizontal="4dp"
            android:text=""
            android:textColor="@color/streak_count_color"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="🔥 12" />
    </LinearLayout>

    <!-- ============================ VOCAB CARD ============================ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardVocab"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_card_pink"
        android:paddingStart="20dp"
        android:paddingEnd="12dp"
        android:paddingTop="16dp"
        android:paddingBottom="22dp">

        <!-- Score line: sits above the word as a small status header (mirrors
             the IDE "file path / metadata" line above editor content). -->
        <TextView
            android:id="@+id/textScore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text=""
            android:textColor="@color/vocab_text"
            android:textSize="22sp"
            app:layout_constraintEnd_toStartOf="@+id/button_hard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="0.85" />

        <!-- accessibilityTraversalAfter pushes the ⚑/✓ actions behind the
             vocab content for screen readers, so users hear the word and
             translation before landing on the buttons that operate on
             them. -->
        <Button
            android:id="@+id/button_hard"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:accessibilityTraversalAfter="@id/textGuessLong"
            android:contentDescription="Flag as hard"
            android:text="⚑"
            android:textSize="20sp"
            app:layout_constraintEnd_toStartOf="@+id/button_learned"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/button_learned"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:accessibilityTraversalAfter="@id/button_hard"
            android:contentDescription="Mark as learned"
            android:text="✓"
            android:textSize="20sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Main foreign word — visually the biggest thing on the screen.
             accessibilityLiveRegion="polite" makes TalkBack announce the
             new word each round so SR users don't have to swipe to
             discover it; the foreign-locale text is set in code so the
             SR uses the right voice. -->
        <TextView
            android:id="@+id/textGuess"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="8dp"
            android:accessibilityLiveRegion="polite"
            android:text=""
            android:textColor="@color/vocab_text"
            android:textSize="34sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/button_learned"
            tools:text="Un mot étrange" />

        <TextView
            android:id="@+id/textReal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="8dp"
            android:text=""
            android:textColor="@color/vocab_text"
            android:textSize="22sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/textGuess"
            app:layout_constraintTop_toBottomOf="@+id/textGuess"
            tools:text="A foreign word" />

        <TextView
            android:id="@+id/textGuessLong"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="8dp"
            android:text=""
            android:textColor="@color/vocab_text"
            android:textSize="22sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/textGuess"
            app:layout_constraintTop_toBottomOf="@+id/textReal"
            tools:text="Ma mère a ressenti une très grande peine lorsqu'elle a appris…" />

        <ImageView
            android:id="@+id/thinking_sparkle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="-4dp"
            android:contentDescription="@null"
            android:src="@drawable/thinking_sparkle"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@+id/textGuessLong"
            app:layout_constraintTop_toTopOf="@+id/textGuessLong" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Flex spacer: absorbs any leftover vertical room between the vocab
         card and the bottom block, instead of letting cards drift apart
         unevenly. minHeight guarantees a visible gap on short screens. -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="12dp" />

    <!-- ===================== LIFETIME PROGRESS CARD ===================== -->
    <!-- setSegmentWeight in QuizController casts the segment LayoutParams to
         LinearLayout.LayoutParams, so the bar row MUST stay a LinearLayout. -->
    <!-- focusable + screenReaderFocusable group the card into a single
         accessibility node; QuizController sets contentDescription on
         cardLifetime each round so SR users hear "234 of 1500 mastered,
         plus 5 today" instead of nothing (the raw segment Views have no
         semantics on their own). -->
    <LinearLayout
        android:id="@+id/cardLifetime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_green"
        android:focusable="true"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:baselineAligned="true"
            android:importantForAccessibility="no"
            android:orientation="horizontal">

            <TextView
                style="@style/CardEyebrow"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="TOTAL PROGRESS" />

            <TextView
                android:id="@+id/textLifetimeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textSize="14sp"
                tools:text="234 / 1500  ·  +5" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:importantForAccessibility="no"
            android:orientation="horizontal">

            <View
                android:id="@+id/segLifetimeMastered"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0"
                android:background="@color/seg_mastered" />

            <View
                android:id="@+id/segLifetimeRemaining"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/progress_track" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===================== ACTIVE PROGRESS CARD ===================== -->
    <LinearLayout
        android:id="@+id/cardActive"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_card_cyan"
        android:focusable="true"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:baselineAligned="true"
            android:importantForAccessibility="no"
            android:orientation="horizontal">

            <TextView
                style="@style/CardEyebrow"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="ACTIVE WORDS" />

            <TextView
                android:id="@+id/textActiveLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textSize="14sp"
                tools:text="8  ·  4  ·  2" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:background="@color/progress_track"
            android:importantForAccessibility="no"
            android:orientation="horizontal">

            <View
                android:id="@+id/segActiveRead"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0"
                android:background="@color/seg_read" />

            <View
                android:id="@+id/segActiveListen"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0"
                android:background="@color/seg_listen" />

            <View
                android:id="@+id/segActiveInvert"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0"
                android:background="@color/seg_invert" />
        </LinearLayout>
    </LinearLayout>

    <!-- =========================== ACTION BUTTONS ===========================
         Clean 2×2 grid via two horizontal rows. Each row hands its two
         children equal weight so buttons span the full available width with
         a uniform 16dp inter-column gap (8dp + 8dp). The destructive Fail and
         the primary Next sit on the top row (more reachable thumb zone). -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        android:paddingHorizontal="8dp">

        <!-- maxLines is intentionally left unset so labels can wrap at the
             user's preferred font scale (a11y "Largest" can double the
             text size). minHeight keeps the touch target at 48 dp even
             on single-line labels. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_fail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:minHeight="48dp"
                android:text="✗ Show me" />

            <Button
                android:id="@+id/button_next"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:minHeight="48dp"
                android:text="✓ I knew it" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_tip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:minHeight="48dp"
                android:text="💡 Hint" />

            <Button
                android:id="@+id/button_new"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:minHeight="48dp"
                android:text="+ New word" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
