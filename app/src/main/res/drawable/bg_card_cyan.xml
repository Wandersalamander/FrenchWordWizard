<?xml version="1.0" encoding="utf-8"?>
<!-- Active-set card: cyan accent (matches the LISTEN segment of the active
     bar — picked over orange/purple to keep the four card stripes visually
     distinct). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/card_surface" />
            <stroke android:width="1dp" android:color="@color/card_edge" />
        </shape>
    </item>
    <item android:height="3dp" android:gravity="top">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="14dp"
                android:topRightRadius="14dp" />
            <solid android:color="@color/monokai_cyan" />
        </shape>
    </item>
</layer-list>
