<?xml version="1.0" encoding="utf-8"?>
<!-- Vocab card: pink accent stripe (the primary attention color) on a lifted
     card surface. The body fills the whole shape; the 3dp stripe sits on top
     with only the upper corners rounded so it reads as a flush "syntax token"
     marker on the panel header. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/card_surface" />
            <stroke android:width="1dp" android:color="@color/card_edge" />
        </shape>
    </item>
    <item android:height="3dp" android:gravity="top">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="14dp"
                android:topRightRadius="14dp" />
            <solid android:color="@color/monokai_pink" />
        </shape>
    </item>
</layer-list>
